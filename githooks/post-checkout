#!/bin/sh

is_branch_checkout=$3
[ "$is_branch_checkout" = "0" ] && exit 0

branch=$(git symbolic-ref HEAD | sed 's|refs/heads/||')
prev_branch=$1
new_branch_head=$2

if git rev-parse --verify "refs/heads/$branch" > /dev/null 2>&1; then
  [ "$prev_branch" != "$new_branch_head" ] && exit 0
fi

pattern="^(feat|fix|rm|docs|chore|refactor|test|style|perf)/.+"

case "$branch" in
  main|master|develop|staging) exit 0 ;;
esac

if ! echo "$branch" | grep -qE "$pattern"; then
  echo ""
  echo "  Warning: branch \"$branch\" doesn't follow naming conventions"
  echo "  Expected format: feat/login-page, fix/auth-bug, etc."
  echo ""
fi